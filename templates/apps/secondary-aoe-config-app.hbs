<form class="{{moduleId}}-config-window flexcol" autocomplete="off">
  <header class="aoe-config-header">
    <h2>{{localize "AOESECONDARY.APP.Title"}}</h2>
    <p class="notes">{{localize "AOESECONDARY.APP.ItemLabel"}} <strong>{{itemName}}</strong></p>
  </header>

  <div class="aoe-config-body">
    <div class="form-group">
      <label>{{localize "AOESECONDARY.UI.EnabledLabel"}}</label>
      <div class="form-fields">
        <input type="checkbox"
               name="flags.{{moduleId}}.secondaryAoe.enabled"
               data-dtype="Boolean"
               {{checked config.enabled}}>
      </div>
      <p class="hint">{{localize "AOESECONDARY.UI.EnabledHint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOESECONDARY.UI.RadiusLabel"}}</label>
      <div class="form-fields">
        <input type="number"
               name="flags.{{moduleId}}.secondaryAoe.radius"
               value="{{config.radius}}"
               min="0"
               step="0.1"
               data-dtype="Number">
      </div>
      <p class="hint">{{localize "AOESECONDARY.UI.RadiusHint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOESECONDARY.UI.IncludePrimaryTargetLabel"}}</label>
      <div class="form-fields">
        <input type="checkbox"
               name="flags.{{moduleId}}.secondaryAoe.includePrimaryTarget"
               data-dtype="Boolean"
               {{checked config.includePrimaryTarget}}>
      </div>
      <p class="hint">{{localize "AOESECONDARY.UI.IncludePrimaryTargetHint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOESECONDARY.UI.TriggerLabel"}}</label>
      <div class="form-fields">
        <select name="flags.{{moduleId}}.secondaryAoe.trigger">
          {{#each triggerChoices as |choice|}}
          <option value="{{choice.value}}" {{#if choice.selected}}selected{{/if}}>{{choice.label}}</option>
          {{/each}}
        </select>
      </div>
      <p class="hint">{{localize "AOESECONDARY.UI.TriggerHint"}}</p>
    </div>

    <div class="form-group">
      <label>{{localize "AOESECONDARY.UI.SecondaryActivityLabel"}}</label>
      <div class="form-fields">
        <select name="flags.{{moduleId}}.secondaryAoe.secondaryActivityId">
          {{#each activityChoices as |choice|}}
          <option value="{{choice.value}}" {{#if choice.selected}}selected{{/if}}>{{choice.label}}</option>
          {{/each}}
        </select>
      </div>
      <p class="hint">
        {{#if hasActivities}}
        {{localize "AOESECONDARY.UI.SecondaryActivityHint"}}
        {{else}}
        {{localize "AOESECONDARY.UI.NoActivitiesHint"}}
        {{/if}}
      </p>
    </div>

    <div class="form-group">
      <label>{{localize "AOESECONDARY.UI.TargetFilterLabel"}}</label>
      <div class="form-fields">
        <select name="flags.{{moduleId}}.secondaryAoe.targetFilter">
          {{#each targetFilterChoices as |choice|}}
          <option value="{{choice.value}}" {{#if choice.selected}}selected{{/if}}>{{choice.label}}</option>
          {{/each}}
        </select>
      </div>
      <p class="hint">{{localize "AOESECONDARY.UI.TargetFilterHint"}}</p>
    </div>

    <div class="aoe-config-readonly">
      <div class="form-group stacked">
        <label>{{localize "AOESECONDARY.UI.SelectionModeLabel"}}</label>
        <div class="form-fields readonly-value">{{selectionModeLabel}}</div>
        <p class="hint">{{localize "AOESECONDARY.UI.SelectionModeHint"}}</p>
      </div>

      <div class="form-group stacked">
        <label>{{localize "AOESECONDARY.UI.DistanceModeLabel"}}</label>
        <div class="form-fields readonly-value">{{distanceModeLabel}}</div>
        <p class="hint">{{localize "AOESECONDARY.UI.DistanceModeHint"}}</p>
      </div>
    </div>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="button" class="dialog-button automation-profile-button" data-action="apply-automation-profile">
      <i class="fas fa-shield-halved"></i>
      {{localize "AOESECONDARY.APP.ApplyAutomationProfile"}}
    </button>
    <button type="submit" class="dialog-button default bright">
      <i class="fas fa-save"></i>
      {{localize "AOESECONDARY.APP.Save"}}
    </button>
    <button type="button" class="dialog-button" data-action="close">
      <i class="fas fa-times"></i>
      {{localize "AOESECONDARY.APP.Close"}}
    </button>
  </footer>
</form>
